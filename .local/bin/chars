#!/bin/sh -x

CACHE_DIR="${XDG_DATA_HOME}/chars"
EMOJI_CACHE="$CACHE_DIR/emoji"
NERD_CACHE="$CACHE_DIR/nerd"

mkdir -p "$CACHE_DIR"

fetch_emoji() {
    if [ ! -f "$EMOJI_CACHE" ]; then
        echo "Downloading Emoji cache..."
        curl -fL "https://unicode.org/Public/emoji/latest/emoji-test.txt" | \
	awk -F'[#;] ' '/; fully-qualified/ {sub(/ E[0-9]+\.[0-9]+/, "", $3); print $3 }' | tee $EMOJI_CACHE
    fi
}

fetch_nerd() {
    if [ ! -f "$NERD_CACHE" ]; then
        echo "Downloading Nerd Fonts cache..."
        curl -s "https://raw.githubusercontent.com/ryanoasis/nerd-fonts/master/glyphnames.json" | \
        jq -r 'to_entries[] | "\(.value.char) \(.key)"' > "$NERD_CACHE"
    fi
}

fetch_emoji
fetch_nerd

SELECTED=$(cat "$EMOJI_CACHE" "$NERD_CACHE" | wmenu -i -l 20 -p "Select Char: ")

if [ -n "$SELECTED" ]; then
    printf "%s" "$SELECTED" | awk '{print $1}' | tr -d '\n' | wtype -
fi
